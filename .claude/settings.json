{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "planning-with-files@planning-with-files": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "项目规则：\n1. 使用中文交流，保持简洁直接\n2. 除非用户明确指定，否则不进行git提交\n3. 执行指令前必须验证准确性\n4. 正确则执行，不正确则反驳"
          }
        ]
      }
    ]
  }
}
